{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/main.py"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/$1"
    }
  ]
}