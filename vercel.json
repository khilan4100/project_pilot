{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 3,
  "services": {
    "frontend": {
      "type": "web",
      "framework": "nextjs",
      "root": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "type": "web",
      "builder": "@vercel/python",
      "runtime": "python3.14",
      "root": "backend",
      "entrypoint": "app/main.py",
      "routePrefix": "/_/backend"
    }
  }
}